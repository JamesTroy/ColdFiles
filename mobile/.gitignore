# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# build / cache artifacts (mirror root patterns so a stray turbo / jest /
# coverage run doesn't deposit untracked files that get accidentally
# `git add .`-ed)
.turbo/
.cache/
coverage/
.nyc_output/

# macOS
.DS_Store
*.pem

# Editor — track only the project-shared bits; everything else stays local.
# Mirrors the root .gitignore allow-list so per-package settings don't
# silently track. Both files were verified benign (Expo extension recco +
# format-on-save action set) — no user paths, no environment-specific config.
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# local env files
.env
.env*.local

# google-services.json IS committed despite being a credential — Firebase
# Android API keys are restricted to package name + SHA-1 fingerprint per
# Google's security model, so leaking the key doesn't grant access outside
# the app. Committing it is what EAS Build needs (it only uploads
# git-tracked files), and it's what most public Expo projects do.
# GoogleService-Info.plist (iOS) follows the same model when we ship there.

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android
