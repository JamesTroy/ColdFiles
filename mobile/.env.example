# Mobile env. Copy to .env and fill in. Expo loads this automatically.
#
# The map (MapLibre GL Native + OpenFreeMap public tiles) needs no API key —
# open-source, community-funded, no signup. The basemap is always available.
#
# Supabase: when these are unset every data hook falls back to sample data —
# see lib/sample-data.ts. Fill them in when you wire to a real Supabase project.
# Service-role keys never go here — public reads only.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# DIAGNOSTIC ONLY — do not set in production builds.
#
# Set EXPO_PUBLIC_ENABLE_NATIVE_MAP=1 to route the Map tab through
# components/cf/maps-view.tsx (native MapLibre) instead of the
# LeafletMap WebView path. Used for diagnosing the half-render
# measurement bug that the project memory feedback_map_top_half_not_render.md
# attributes to our parent layout chain (NOT to MapLibre itself).
#
# Production AAB does not set this — the variable is consulted at
# bundle time, so leaving it unset in eas.json's production env block
# guarantees the user-facing build keeps using LeafletMap.
EXPO_PUBLIC_ENABLE_NATIVE_MAP=
