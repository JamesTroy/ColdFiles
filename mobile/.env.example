# Mobile env. Copy to .env and fill in. Expo loads this automatically and
# substitutes EXPO_PUBLIC_* values into app.config.ts at build time.
#
# Service-role keys never go here — public reads only.
# When Supabase vars are unset the app falls back to sample data — see
# lib/sample-data.ts.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps API key (Android). Required for the basemap to render on
# Android — without it the map area is blank gray. Get one at:
#   https://console.cloud.google.com/google/maps-apis
# Enable "Maps SDK for Android", restrict the key to the Android package
# `com.matteblackdev.coldfile`, and paste here. Free tier covers the early
# launch comfortably (~$200/mo of map services).
#
# iOS uses Apple Maps by default — no key required there.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_ANDROID=
