# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# Firebase / Google Services config — per-environment credentials. Not a hard
# secret (API key is restricted to package + SHA-1) but still scoped to the
# current Firebase project and shouldn't ride into git.
google-services.json
GoogleService-Info.plist

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android
