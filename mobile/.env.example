# Mobile env. Copy to .env and fill in. Expo loads this automatically.
#
# Variables MUST start with EXPO_PUBLIC_ to be exposed to the client bundle.
# Service-role keys never go here — public reads only.
#
# When unset, the app falls back to sample data so designers can iterate the
# UI without a backend. See lib/sample-data.ts.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox public token (Week 5b).
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=
